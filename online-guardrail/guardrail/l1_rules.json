  "sql_injection_patterns": [
    "SELECT\\s+\\*\\s+FROM\\s+\\w+\\s+WHERE\\s+\\w+\\s*=\\s*['\\\"]\\s*\\+",
    "SELECT\\s+.*\\|\\|\\s*",
    "execute\\s*\\(\\s*['\\\"].*\\+",
