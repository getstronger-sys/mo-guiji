  "system_write_path_patterns": [
    "^/etc/",
    "^/usr/bin/",
    "^/bin/",
    "^/sbin/",
    "^C:\\\\Windows\\\\",
    "^C:\\\\Program Files\\\\"
  ],
  "insecure_code_patterns": [
    {
      "pattern": "\\beval\\s*\\(",
      "cwe_id": "CWE-94",
      "description": "eval() executes arbitrary code"
    },
    {
      "pattern": "\\bexec\\s*\\(",
      "cwe_id": "CWE-94",
      "description": "exec() executes arbitrary code"
    },
    {
      "pattern": "subprocess\\.(call|Popen|run)\\([^)]*shell\\s*=\\s*True",
      "cwe_id": "CWE-78",
      "description": "subprocess with shell=True"
    },
    {
      "pattern": "os\\.system\\s*\\(",
      "cwe_id": "CWE-78",
      "description": "os.system command injection risk"
    },
    {
      "pattern": "pickle\\.loads?\\s*\\(",
      "cwe_id": "CWE-502",
      "description": "unsafe pickle deserialization"
    },
    {
      "pattern": "yaml\\.load\\s*\\(",
      "cwe_id": "CWE-502",
      "description": "unsafe yaml.load"
    },
    {
      "pattern": "innerHTML\\s*=",
      "cwe_id": "CWE-79",
      "description": "DOM XSS via innerHTML"
    },
    {
      "pattern": "document\\.write\\s*\\(",
      "cwe_id": "CWE-79",
      "description": "DOM XSS via document.write"
    },
    {
      "pattern": "SELECT\\s+\\*\\s+FROM\\s+\\w+\\s+WHERE\\s+\\w+\\s*=\\s*['\\\"]\\s*\\+",
      "cwe_id": "CWE-89",
      "description": "SQL string concatenation"
    }
  ]
}
